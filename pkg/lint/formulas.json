  "forbidden_patterns": [
    {
      "pattern": "now.utc",
      "message": "`.utc` is not a valid Workato method; use `now.in_time_zone(\"UTC\")` or `now.strftime('%Y-%m-%dT%H:%M:%SZ')`"
    },
    {
      "pattern": ".parse_json",
      "message": "`.parse_json` is not a valid Workato formula method; use the `json_parser` connector's `parse_json_v2` action instead"
    }
  ]
