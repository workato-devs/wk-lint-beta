{
  "name": "standard",
  "description": "Baseline lint profile — most rules emit warnings",
  "rules": {
    "INVALID_JSON": "error",
    "CODE_WRAPPED_IN_RECIPE": "error",
    "MISSING_TOP_LEVEL_KEYS": "error",
    "CODE_NOT_OBJECT": "error",
    "CONFIG_INVALID": "error",
    "STEP_MISSING_KEYWORD": "error",
    "STEP_MISSING_NUMBER": "error",
    "NUMBER_NOT_INTEGER": "error",
    "STEP_MISSING_UUID": "error",
    "UUID_TOO_LONG": "error",
    "STEP_NUMBERING": "warn",
    "UUID_UNIQUE": "error",
    "UUID_DESCRIPTIVE": "warn",
    "TRIGGER_NUMBER_ZERO": "error",
    "FILENAME_MATCH": "warn",
    "CONFIG_NO_WORKATO": "warn",
    "CONFIG_PROVIDER_MATCH": "warn",
    "ACTION_NAME_VALID": "warn",
    "RESPONSE_CODES_DEFINED": "info",
    "IF_NO_PROVIDER": "warn",
    "ELSE_NO_PROVIDER": "warn",
    "CATCH_PROVIDER_NULL": "warn",
    "CATCH_HAS_AS": "warn",
    "TRY_NO_AS": "warn",
    "CATCH_HAS_RETRY": "info",
    "NO_ELSIF": "error",
    "FORMULA_METHOD_INVALID": "warn",
    "FORMULA_FORBIDDEN_PATTERN": "warn",
    "DP_VALID_JSON": "error",
    "DP_LHS_NO_FORMULA": "warn",
    "DP_INTERPOLATION_SINGLE": "warn",
    "DP_FORMULA_CONCAT": "warn",
    "DP_NO_OUTER_PARENS": "info",
    "DP_NO_BODY_NATIVE": "warn",
    "DP_CATCH_PROVIDER": "warn",
    "EIS_MIRRORS_INPUT": "warn",
    "EIS_NESTED_MATCH": "warn",
    "EIS_NAME_MATCH": "warn",
    "EIS_NO_CONNECTOR_INTERNAL": "warn",
    "EIS_OUTPUT_MIRRORS_INPUT": "info",
    "CATCH_LAST_IN_TRY": "error",
    "ELSE_LAST_IN_IF": "error",
    "SUCCESS_BEFORE_CATCH": "warn",
    "TERMINAL_COVERAGE": "warn",
    "ALL_PATHS_RETURN": "warn",
    "CATCH_RETURNS_ALL_FIELDS": "warn",
    "RECIPE_CALL_ZIP_NAME": "warn",
    "DP_LINE_RESOLVES": "warn",
    "DP_PROVIDER_MATCHES": "warn",
    "DP_STEP_REACHABLE": "warn",
    "DP_TRIGGER_PATH": "info"
  }
