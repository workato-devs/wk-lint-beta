{
  "name": "strict",
  "description": "Strict lint profile — escalates key rules to errors",
  "extends": "standard",
  "rules": {
    "STEP_NUMBERING": "warn",
    "UUID_UNIQUE": "error",
    "UUID_DESCRIPTIVE": "warn",
    "TRIGGER_NUMBER_ZERO": "error",
    "FILENAME_MATCH": "warn",
    "CONFIG_NO_WORKATO": "error",
    "CONFIG_PROVIDER_MATCH": "error",
    "ACTION_NAME_VALID": "error",
    "RESPONSE_CODES_DEFINED": "warn",
    "IF_NO_PROVIDER": "error",
    "ELSE_NO_PROVIDER": "error",
    "CATCH_PROVIDER_NULL": "error",
    "CATCH_HAS_AS": "error",
    "TRY_NO_AS": "error",
    "CATCH_HAS_RETRY": "warn",
    "NO_ELSIF": "error",
    "FORMULA_METHOD_INVALID": "error",
    "FORMULA_FORBIDDEN_PATTERN": "error",
    "DP_VALID_JSON": "error",
    "DP_LHS_NO_FORMULA": "error",
    "EIS_MIRRORS_INPUT": "error",
    "EIS_NAME_MATCH": "error",
    "ALL_PATHS_RETURN": "error",
    "TERMINAL_COVERAGE": "error",
    "CATCH_RETURNS_ALL_FIELDS": "error",
    "RECIPE_CALL_ZIP_NAME": "error",
    "DP_LINE_RESOLVES": "error",
    "DP_PROVIDER_MATCHES": "error",
    "DP_STEP_REACHABLE": "error"
  }
}
